                  "});\r",
                  "\r",
                  "pm.test(\"Réponse contient un token\", function () {\r",
                  "    const json = pm.response.json();\r",
                  "    pm.expect(json).to.have.property(\"token\");\r",
                  "    pm.expect(json.token).to.be.a(\"string\");\r",
                  "});\r",
                  "\r",
                  "pm.test(\"token_type est Bearer\", function () {\r",
                  "    const json = pm.response.json();\r",
                  "    pm.expect(json.token_type).to.eql(\"Bearer\");\r",
